# Runtime implemented by the FastAPI service.
DHURANDHAR_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DHURANDHAR_EVENT_LOG=./backend/data/events.jsonl
DHURANDHAR_SEED_DEMO=true
DHURANDHAR_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Frontend development server. The production build uses /api on the same origin.
VITE_API_BASE_URL=http://localhost:8000/api

# Safe by default: deterministic replay, no model calls, no repository writes.
DHURANDHAR_RUNTIME=deterministic
DHURANDHAR_ENABLE_CODEX_RUNTIME=false
# Third, independent opt-in. When true, Codex may edit only CODEX_WORKDIR;
# commit, push, merge, and deploy remain outside; repository commands keep the
# workspace-write sandbox's network restriction.
DHURANDHAR_CODEX_APPLY_CHANGES=false
DHURANDHAR_CODEX_BIN=codex
DHURANDHAR_CODEX_WORKDIR=.
DHURANDHAR_CODEX_TIMEOUT_SECONDS=120
# GPT-5.6 SUBMISSION GATE: After access, set BOTH models to gpt-5.6, rerun the live path, and only then update README claims.
DHURANDHAR_IMPLEMENTATION_MODEL=gpt-5.5
DHURANDHAR_REVIEWER_MODEL=gpt-5.5
# Required for every mutation in Codex mode or a non-development deployment.
# Keep it server-side; the public replay UI is intentionally read-only.
DHURANDHAR_OPERATOR_TOKEN=
