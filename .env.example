# Runtime implemented by the FastAPI seed
DHURANDHAR_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DHURANDHAR_EVENT_LOG=./backend/data/events.jsonl
DHURANDHAR_SEED_DEMO=true
DHURANDHAR_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Frontend development server. The production build uses /api on the same origin.
VITE_API_BASE_URL=http://localhost:8000/api

# Safe by default: deterministic replay, no model calls, no repository writes.
DHURANDHAR_DEMO_MODE=sample
DHURANDHAR_RUNTIME=deterministic
DHURANDHAR_ENABLE_CODEX_RUNTIME=false
# Third, independent opt-in. When true, Codex may edit only CODEX_WORKDIR;
# commit, push, merge, and deploy remain outside; repository commands keep the
# workspace-write sandbox's network restriction.
DHURANDHAR_CODEX_APPLY_CHANGES=false
DHURANDHAR_CODEX_BIN=codex
DHURANDHAR_CODEX_WORKDIR=.
DHURANDHAR_CODEX_TIMEOUT_SECONDS=120
DHURANDHAR_WRITE_ENABLED=false
DHURANDHAR_AUTO_MERGE=false
DHURANDHAR_SELF_IMPROVEMENT_ENABLED=false
DHURANDHAR_REQUIRE_CLEAN_WORKTREE=true
DHURANDHAR_REQUIRE_CI=true

# Live model integration. Leave blank for sample mode.
OPENAI_API_KEY=
# Model selection is recorded for live provenance; the local Codex CLI owns its
# own authenticated model configuration.
OPENAI_MODEL=gpt-5.6

# Live GitHub integration. Use a fine-grained token and a disposable repository.
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/sandbox-repository
GITHUB_DEFAULT_BRANCH=main
DHURANDHAR_ALLOWED_REPOSITORIES=owner/sandbox-repository

# Bounded execution
DHURANDHAR_MAX_PARALLEL_RUNS=1
DHURANDHAR_MAX_STEPS_PER_RUN=12
DHURANDHAR_MAX_INPUT_TOKENS_PER_RUN=250000
DHURANDHAR_MAX_OUTPUT_TOKENS_PER_RUN=50000
DHURANDHAR_MAX_SPEND_USD_PER_RUN=25
DHURANDHAR_RUN_TIMEOUT_SECONDS=3600

# Comma-separated paths that require explicit human approval when changed.
DHURANDHAR_PROTECTED_PATHS=.github/,Dockerfile,render.yaml,backend/app/policies/

# Optional release metadata
APP_VERSION=dev
GIT_SHA=local
